PUTIYUAN_HOST=0.0.0.0
PUTIYUAN_PORT=3000
PUTIYUAN_DB_PATH=/var/lib/putiyuan/data.db
PUTIYUAN_SECRET_KEY=change-this-to-a-long-random-secret

# Email (SMTP) for email verification code binding
# PUTIYUAN_SMTP_HOST=smtp.example.com
# PUTIYUAN_SMTP_PORT=587
# PUTIYUAN_SMTP_USER=noreply@example.com
# PUTIYUAN_SMTP_PASS=your-smtp-password
# PUTIYUAN_SMTP_FROM=noreply@example.com

# Optional AI config can still be managed in admin panel.
# PUTIYUAN_AI_API_KEY=
# PUTIYUAN_AI_BASE_URL=https://api.openai.com/v1
# PUTIYUAN_AI_TEXT_MODEL=gpt-4o-mini
# PUTIYUAN_AI_VISION_MODEL=gpt-4o-mini
