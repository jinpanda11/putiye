[Unit]
Description=Putiyuan Web App
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=putiyuan
Group=putiyuan
WorkingDirectory=/opt/putiyuan/current
EnvironmentFile=-/etc/putiyuan.env
ExecStart=/usr/bin/python3 /opt/putiyuan/current/server.py
Restart=always
RestartSec=3

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/putiyuan /opt/putiyuan/current

[Install]
WantedBy=multi-user.target
